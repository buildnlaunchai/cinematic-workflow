# Cinematic Workflow — environment variables.
#
# Copy this file to .env.local and fill in the values. .env.local is gitignored
# and must never be committed. Every value below is blank on purpose: this file
# documents what is needed, never what yours are.
#
# Variables prefixed NEXT_PUBLIC_ are embedded into the browser bundle and are
# readable by anyone using the app. Variables without that prefix stay on the
# server. Nothing secret may ever carry a NEXT_PUBLIC_ prefix — preflight.sh
# fails the build if it does.
#
# NOTE ON THE R2 BLOCK AT THE BOTTOM: those are NOT Next.js env vars. They are
# Supabase Edge Function secrets, set with `supabase secrets set`, and are read
# by the upload functions via Deno.env — never by the app. They live here so the
# deploy guide has one complete list.


# ============================================================================
# Next.js / app runtime
# ============================================================================

# --- Run mode ---------------------------------------------------------------

# Which mode the app boots in. Default is standalone.
#   standalone = the app runs on its own and uses its own Supabase Auth.
#   embedded   = the app runs inside the Build & Launch hub in an iframe and
#                trusts a hub-signed token instead of showing its own login.
# Leave this as standalone unless you are the hub operator.
NEXT_PUBLIC_APP_MODE=standalone


# --- Supabase (required in both modes) --------------------------------------

# Your Supabase project's API URL. Looks like https://<project-ref>.supabase.co
# The upload client also derives the Edge Functions base from this value.
# Where: Supabase dashboard -> your project -> Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# The publishable/anon key. Safe to expose in the browser: it is powerless on its
# own because Row Level Security decides what it may read, and guest /share reads
# go through a SECURITY DEFINER RPC that hands back only a fixed public projection.
# Where: Settings -> API -> Project API keys -> anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service role key. SERVER ONLY — this bypasses Row Level Security entirely.
# Anyone holding it can read and write every row in your database. Never give it
# a NEXT_PUBLIC_ prefix, never paste it into client code, never commit it.
# Only embedded mode uses it (to create the local profile row after verifying the
# hub's token). Standalone deployments may leave it blank.
# Where: Settings -> API -> Project API keys -> service_role -> Reveal
SUPABASE_SERVICE_ROLE_KEY=


# --- Embedded mode only ------------------------------------------------------

# The hub's PUBLIC key (PEM), used to verify the signature on tokens the hub
# sends. A public key is not a secret — it can only verify, never sign — but a
# wrong value here means every token is rejected and the app shows locked state.
# Required when NEXT_PUBLIC_APP_MODE=embedded. Ignored in standalone.
# Where: the Build & Launch hub operator gives you this.
#
# Multi-line PEM — how you paste it matters, and getting it wrong looks like
# "this user has no access" rather than like a config error:
#   · In a DASHBOARD (Vercel): paste the single-line \n-escaped form. Do NOT put
#     quotes around it. A quoted PEM fails to parse, so every hub token is
#     rejected and every member sees locked state.
#   · In a .env FILE: either the \n-escaped one-liner, or the real multi-line PEM
#     wrapped in quotes. Both work.
HUB_PUBLIC_KEY=

# The hub origin(s) allowed to put this app in an iframe. Pins the
# frame-ancestors CSP directive. Scheme + host, no trailing slash. May be a
# SPACE-SEPARATED LIST when the hub is reachable at more than one origin:
#   HUB_ORIGIN="https://buildnlaunchai.com https://www.buildnlaunchai.com"
# Required when NEXT_PUBLIC_APP_MODE=embedded: the BUILD fails without it rather
# than shipping an app any site could frame. Ignored in standalone. Read at build
# time, so changing it needs a redeploy, not just a restart.
HUB_ORIGIN=


# ============================================================================
# Cloudflare R2 — Supabase Edge Function SECRETS (NOT Next.js env)
# ============================================================================
# Set these with the Supabase CLI, once per project, NOT in .env.local:
#
#   supabase secrets set R2_ENDPOINT=... R2_ACCESS_KEY=... R2_SECRET_KEY=... \
#                        R2_BUCKET=... R2_PUBLIC_URL_BASE=... ALLOWED_ORIGIN=...
#
# They are read only by supabase/functions/{generate-upload-url,r2-multipart-upload}
# via Deno.env. Videos (and comment attachments) upload straight to your own R2
# bucket; nothing is stored in Supabase Storage.
#
# Where to get R2 values: Cloudflare dashboard -> R2 -> your bucket, and
# R2 -> Manage R2 API Tokens for the access key / secret.

# S3 API endpoint for your account, e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=

# R2 API token pair (an "Object Read & Write" token scoped to the bucket).
R2_ACCESS_KEY=
R2_SECRET_KEY=

# The bucket name uploads are written to.
R2_BUCKET=

# The PUBLIC base URL the stored objects are served from — either the bucket's
# r2.dev public URL, or your custom domain. The upload functions return
# `${R2_PUBLIC_URL_BASE}/${key}` as the video_url. No trailing slash.
# Example shape: https://pub-<hash>.r2.dev
R2_PUBLIC_URL_BASE=

# The app origin allowed to call the upload functions (CORS). Optional — defaults
# to "*", which is safe here because the functions authenticate with a Bearer
# token, not cookies. Pin it to your app's URL (e.g. https://yourapp.vercel.app)
# if you prefer.
ALLOWED_ORIGIN=

# ----------------------------------------------------------------------------
# REQUIRED R2 BUCKET CORS CONFIG — multipart uploads HARD-FAIL without it.
# ----------------------------------------------------------------------------
# In Cloudflare -> R2 -> your bucket -> Settings -> CORS Policy, add a rule that
# allows your app origin to PUT/GET, and — critically — EXPOSES the ETag header.
# The multipart client reads the ETag off each part's PUT response to assemble
# the final object; if CORS doesn't expose it, every large-file upload dies with
# "no ETag was returned by R2". Example:
#
#   [
#     {
#       "AllowedOrigins": ["https://yourapp.vercel.app"],
#       "AllowedMethods": ["GET", "PUT"],
#       "AllowedHeaders": ["*"],
#       "ExposeHeaders": ["ETag"]
#     }
#   ]
