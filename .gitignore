# Secrets — never commit. preflight.sh fails the build if this file is tracked.
.env.local
.env*.local

# Dependencies
node_modules/
.pnpm-store/

# Next.js build output
.next/
out/
next-env.d.ts

# Distribution zips produced by `pnpm run dist`
dist/

# Supabase CLI local state. Holds the linked project ref and CLI caches —
# machine-specific, and .temp can contain access tokens.
supabase/.temp/
supabase/.branches/

# OS / editor noise
.DS_Store
*.log

# TypeScript incremental build cache
*.tsbuildinfo

# Internal Build & Launch architecture doc — not published (this repo is public).
# dist.sh already strips it from distributor zips; keep it out of git too.
TEMPLATE.md
